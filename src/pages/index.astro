---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import VideoCard from '../components/VideoCard.astro';
import { getCollection } from 'astro:content';
import videos from '../data/videos.json';

const posts = await getCollection('blog');
const sortedPosts = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout>
  <Header />

  <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-8 sm:px-6 lg:px-8">
    <section id="blog" class="mb-12 scroll-mt-20">
      <h2 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white">Blog</h2>
      {sortedPosts.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {sortedPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.slug}
            />
          ))}
        </div>
      ) : (
        <p class="text-gray-500 dark:text-gray-400">No blog posts yet. Check back soon!</p>
      )}
    </section>

    <section id="videos" class="mb-12 scroll-mt-20">
      <h2 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white">Videos</h2>
      {videos.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {videos.map((video) => (
            <VideoCard id={video.id} title={video.title} description={video.description} />
          ))}
        </div>
      ) : (
        <p class="text-gray-500 dark:text-gray-400">No videos yet. Check back soon!</p>
      )}
    </section>

    <section id="about" class="scroll-mt-20">
      <h2 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white">About Me</h2>
      <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-900">
        <p class="text-gray-700 dark:text-gray-300">
          I'm an AWS Cloud Security enthusiast. I create short-form content breaking down complex
          security topics into bite-sized tips. Follow along to level up your cloud security game.
        </p>
        <div class="mt-4 flex gap-4">
          <a
            href="https://github.com/ALeonard9"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300"
          >
            GitHub
          </a>
          <a
            href="https://linkedin.com/in/ALeonard9"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300"
          >
            LinkedIn
          </a>
          <a
            href="https://www.youtube.com/@Fortress_in_the_Sky"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300"
          >
            YouTube
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
