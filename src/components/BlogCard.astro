---
export interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
}

const { title, description, date, slug } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition hover:shadow-md dark:border-gray-700 dark:bg-gray-900">
  <time class="text-sm text-gray-500 dark:text-gray-400" datetime={date.toISOString()}>{formattedDate}</time>
  <h3 class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">
    <a href={`${import.meta.env.BASE_URL}/blog/${slug}`} class="text-inherit no-underline hover:text-blue-600 dark:hover:text-blue-400">{title}</a>
  </h3>
  <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">{description}</p>
  <a
    href={`${import.meta.env.BASE_URL}/blog/${slug}`}
    class="mt-3 inline-block text-sm font-medium text-blue-600 no-underline hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300"
  >
    Read more &rarr;
  </a>
</article>
